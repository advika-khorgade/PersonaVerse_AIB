# Workflow Tools Configuration
MOCK_MODE=false
GEMINI_API_KEY=

# Server Configuration
PORT=3001

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=ap-south-1

# AWS Service Configuration
S3_BUCKET_NAME=personaverse-storage
DYNAMODB_TABLE_HISTORY=personaverse-user-history
DYNAMODB_TABLE_PERSONAS=personaverse-personas
DYNAMODB_TABLE_USERS=personaverse-users
DYNAMODB_TABLE_CALENDAR=personaverse-calendar

# Authentication
JWT_SECRET=personaverse-secret-key-change-in-production

# Bedrock Configuration
# Using Claude Sonnet 4.5 via Global Inference Profile (required for on-demand throughput)
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=us-east-1

# Feature Flags
ENABLE_VOICE_TO_TEXT=true
ENABLE_MULTILINGUAL=true
ENABLE_HISTORY_STORAGE=true
ENABLE_BEDROCK=true
ENABLE_EMAIL_NOTIFICATIONS=true

# AI Provider Selection (Priority: Groq > Bedrock > Mock)
USE_GROQ=true
GROQ_API_KEY=your-groq-api-key-here
USE_BEDROCK_MOCKS=false

# Email Configuration (Gmail SMTP)
# IMPORTANT: Replace with your actual Gmail credentials for email notifications to work
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-actual-email@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_FROM_NAME=PersonaVerse AI
EMAIL_FROM_ADDRESS=your-actual-email@gmail.com

# Supported Languages (ISO 639-1 codes)
SUPPORTED_LANGUAGES=en,hi,ta,te,bn,mr,gu,kn,ml,pa